# =============================================================================
# MIDI STUDIO BACKEND — ENVIRONMENT CONFIGURATION
# =============================================================================
# Скопируйте этот файл в .env и заполните значениями
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# TELEGRAM BOT CONFIGURATION
# -----------------------------------------------------------------------------
# Получите токен бота у @BotFather в Telegram
# https://core.telegram.org/bots#how-do-i-create-a-bot
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# -----------------------------------------------------------------------------
# SERVER CONFIGURATION
# -----------------------------------------------------------------------------
PORT=3001

# Режим работы: development или production
NODE_ENV=development

# -----------------------------------------------------------------------------
# CORS CONFIGURATION
# -----------------------------------------------------------------------------
# Разрешённые origins (через запятую)
# В production используйте только HTTPS!
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# Разрешить запросы без Origin (мобильные приложения, curl)
# В production установите в false
ALLOW_NO_ORIGIN=true

# -----------------------------------------------------------------------------
# TELEGRAM VALIDATION
# -----------------------------------------------------------------------------
# Пропускать валидацию Telegram initData в development
# В production должно быть false или не установлено
SKIP_TELEGRAM_VALIDATION=true

# Максимальный возраст данных Telegram (в секундах)
# 86400 = 24 часа
TELEGRAM_DATA_MAX_AGE=86400

# -----------------------------------------------------------------------------
# SECURITY (опционально)
# -----------------------------------------------------------------------------
# Для дополнительной безопасности раскомментируйте и настройте

# Secret key для сессий (если потребуется)
# SESSION_SECRET=your-super-secret-key-here-at-least-32-characters

# Rate limiting (количество запросов в минуту)
# RATE_LIMIT_MAX=30
# RATE_LIMIT_WINDOW_MS=60000
